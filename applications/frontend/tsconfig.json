{
  "compilerOptions": {
    "baseUrl": "./src",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "paths": {
      "@app/*": ["app/*"],
      "@pages/*": ["pages/*"],
      "@widgets/*": ["widgets/*"],
      "@features/*": ["features/*"],
      "@entities/*": ["entities/*"],
      "@shared/*": ["shared/*"]
    },
    "strict": true,
    "isolatedModules": false,
    "allowSyntheticDefaultImports": true,
    "jsx": "react-jsx",
    "allowJs": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "target": "ESNext",
    "moduleResolution": "node",
    "alwaysStrict": true,
    "module": "ESNext",
    "pretty": true,
    "noEmit": true,
    "downlevelIteration": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "dist"
  },
  "include": ["src", "vite.config.ts", "vitest.shims.d.ts", "i18next.config.ts"],
  "ts-node": {
    "compilerOptions": {
      "module": "CommonJS"
    }
  }
}
